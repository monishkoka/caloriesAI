# ---------------------------------------------------------------------------
# AI Health Coach — Environment Variables
# Copy this file to `.env` and fill in the values. Anything prefixed with
# EXPO_PUBLIC_ is embedded in the client bundle and is NOT secret.
# ---------------------------------------------------------------------------

# Firebase (Web SDK config — safe to expose, secured by Firestore rules)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# OpenAI — point this at YOUR backend proxy, never the raw OpenAI endpoint.
# The client must never hold an OpenAI secret key.
EXPO_PUBLIC_OPENAI_PROXY_URL=

# EAS
EAS_PROJECT_ID=
